---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter(post => !post.data.draft && post.data.lang === 'en')
    .map((post) => ({
      params: { slug: post.slug.replace(/-en$/, '') },
      props: post,
    }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<BaseLayout 
  title={`${post.data.title} - vremyavnikuda`}
  description={post.data.description}
  canonicalUrl={post.data.sourceUrl}
>
  <script is:inline>
    window.MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']],
        processEscapes: true,
      },
      options: {
        skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
      },
    };
  </script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js" async></script>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <header class="mb-12">
      <time class="text-sm text-[var(--color-text-secondary)]">
        {post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}
      </time>
      <h1 class="text-4xl md:text-5xl font-bold mt-3 mb-6">
        {post.data.title}
      </h1>

      {post.data.source === 'twir' && post.data.sourceUrl && (
        <div class="glass-panel rounded-2xl px-5 py-4 text-sm text-[var(--color-text-secondary)]">
          <p class="mb-2 text-xs uppercase tracking-[0.2em] text-primary-300">Imported source</p>
          <p class="mb-2">
            Imported from <a href={post.data.sourceUrl}>This Week in Rust</a>
            {post.data.issueNumber && ` issue ${post.data.issueNumber}`}. This page keeps the post in the local blog layout.
          </p>
          {post.data.license && <p>License: {post.data.license}</p>}
          <p class="mt-2">
            <a href={post.data.sourceUrl}>Open the original issue →</a>
          </p>
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none article-prose">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-[var(--color-border)]">
      <a 
        href="/en/blog" 
        class="inline-flex items-center text-primary-400 hover:underline"
      >
        ← Back to blog
      </a>
    </footer>
  </article>
</BaseLayout>
