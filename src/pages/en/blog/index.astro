---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const lang = 'en';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft && post.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog - vremyavnikuda" description="Articles about software development and technology">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">Blog</h1>
      <p class="text-xl text-[var(--color-text-secondary)]">
        Thoughts on software development, programming, and technology
      </p>
    </header>

    {allPosts.length === 0 ? (
      <p class="text-[var(--color-text-secondary)]">No posts yet. Check back soon!</p>
    ) : (
      <div class="space-y-12">
        {allPosts.map((post) => (
          <article class="group">
            <a href={`/en/blog/${post.slug.replace(/-en$/, '')}`} class="block">
              {post.data.source === 'twir' && (
                <div class="mb-3 flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.2em] text-primary-300">
                  <span class="rounded-full border border-primary-400/40 bg-primary-400/10 px-2.5 py-1">
                    This Week in Rust
                  </span>
                  {post.data.issueNumber && <span>Issue {post.data.issueNumber}</span>}
                </div>
              )}
              <time class="text-sm text-[var(--color-text-secondary)]">
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              <h2 class="text-3xl font-semibold mt-2 mb-3 group-hover:text-primary-400 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-[var(--color-text-secondary)] mb-4">
                {post.data.description}
              </p>
            </a>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
